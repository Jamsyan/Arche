{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": true,
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(uv *)",
      "Bash(uv run:*)",
      "Bash(uv sync)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run mypy *)",
      "Bash(uv run pre-commit *)",
      "Bash(git *)",
      "Bash(python *)",
      "Bash(ls *)",
      "Bash(ls -la *)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(jq *)",
      "Bash(tree *)",
      "Bash(dir *)",
      "Bash(type *)",
      "Bash(which *)",
      "Bash(cd * && git *)",
      "Bash(cd * && echo * && python *)",
      "Bash(cd * && python *)",
      "Bash(echo * | *)",
      "Bash(test *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(cd * && uv *)",
      "Bash(docker *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(gh *)",
      "Read",
      "Glob",
      "Grep",
      "Write",
      "Edit",
      "NotebookEdit"
    ],
    "deny": []
  }
}