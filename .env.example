# Veil 环境配置
# 复制为 .env 后填入实际值：cp .env.example .env
#
# 加载优先级：操作系统环境变量 > .env 文件 > 代码默认值
# 所有以 VEIL_ 开头的环境变量也会被自动读取

# === 核心配置 ===
# 数据库连接字符串（SQLite / PostgreSQL）
# SQLite: sqlite+aiosqlite:///./veil.db
# PostgreSQL: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./veil.db

# 用于 JWT 签名 / Session 加密的密钥，生产环境务必更换
SECRET_KEY=change-me-to-random-string

# 本地文件存储根目录（上传文件、爬虫数据等）
STORAGE_PATH=./storage

# 允许跨域请求的前端地址，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173

# === 日志 ===
# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL，默认 INFO
LOG_LEVEL=INFO
# 日志文件路径，不配置则仅输出到控制台
# LOG_FILE=./logs/Arche.log

# === 阿里云 OSS（冷存储）===
# 用于冷数据归档（7 天未访问文件自动从 MinIO 迁移到阿里云 OSS）
# 不配置则冷迁移功能不可用，不影响 MinIO 正常使用

# 阿里云 AccessKey ID
OSS_ACCESS_KEY_ID=
# 阿里云 AccessKey Secret
OSS_ACCESS_KEY_SECRET=
# OSS Endpoint，不同区域不同地址
# 上海: https://oss-cn-shanghai.aliyuncs.com
# 北京: https://oss-cn-beijing.aliyuncs.com
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
# 存储桶名称
OSS_BUCKET_NAME=

# === GitHub 代理 ===
# 用于代理 GitHub API 请求（模型/权重元数据获取等）

# GitHub 个人访问令牌，用于提高 API 频率限制（可选但推荐）
GITHUB_TOKEN=
# GitHub API 基础 URL
GITHUB_API_BASE=https://api.github.com
# GitHub Raw 文件基础 URL
GITHUB_RAW_BASE=https://raw.githubusercontent.com
# 缓存 TTL（秒），默认 300
GITHUB_CACHE_TTL=300
# 请求超时（秒），默认 30
GITHUB_TIMEOUT=30

# === 爬虫 ===
# 爬虫初始种子 URL，逗号分隔
CRAWLER_SEEDS=https://www.zhihu.com,https://tieba.baidu.com
# 爬虫数据存储根目录
CRAWLER_STORAGE_ROOT=data/crawler

# === 云训练 ===
# 训练 Provider，可选: mock（本地模拟）| zhixingyun（智星云）| aliyun（阿里云 ECS）
CLOUD_PROVIDER=zhixingyun

# --- 智星云 Provider ---
# 智星云 OpenAPI Key
ZHIXINGYUN_API_KEY=
# 智星云 OpenAPI Secret
ZHIXINGYUN_API_SECRET=

# --- 阿里云 ECS Provider ---
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
# 区域 ID
ALIYUN_REGION=cn-shanghai
# 安全组 ID
ALIYUN_SECURITY_GROUP_ID=
# 虚拟交换机 ID
ALIYUN_VSWITCH_ID=
# 镜像 ID
ALIYUN_IMAGE_ID=

# --- 通用 Provider（mock 等）---
# 非智星云/阿里云时使用的通用凭证，mock 模式下可为空
CLOUD_API_KEY=
CLOUD_API_SECRET=

# === OSS 对象存储（MinIO）===
# MinIO 本地对象存储服务，开发/生产默认使用
# MinIO 连接端点（host:port）
MINIO_ENDPOINT=localhost:9000
# MinIO 管理员用户名
MINIO_ROOT_USER=veiladmin
# MinIO 管理员密码
MINIO_ROOT_PASSWORD=veiladmin123
# 是否启用 TLS 连接 MinIO（true / false）
MINIO_SECURE=false

# === OSS 配额与限流 ===
# P1（VIP）用户默认存储配额（字节），默认 1GB
DEFAULT_P1_QUOTA_BYTES=
# 全局写入速率限制（字节/秒），默认 10MB/s
OSS_GLOBAL_RATE_LIMIT_BYTES=

# === 系统监控 ===
# 系统资源采集间隔（秒），默认 10
MONITOR_COLLECT_INTERVAL=

# === 敏感词 ===
# 敏感词列表，逗号分隔，用于博客内容过滤
SENSITIVE_WORDS=

# === PostgreSQL（docker-compose 使用）===
POSTGRES_DB=veil
POSTGRES_USER=veil
POSTGRES_PASSWORD=veil

# === MinIO（docker-compose 使用）===
# 注意：MINIO_ROOT_USER / MINIO_ROOT_PASSWORD 已在上方 OSS 对象存储部分定义
