# === 核心配置 ===

# 数据库连接字符串
# 开发环境: sqlite+aiosqlite:///./data/veil.db
# 生产环境: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/veil.db

# JWT 签名密钥（生产环境必须更换）
SECRET_KEY=change-me-to-random-string

# 本地文件存储根目录
STORAGE_PATH=./storage

# 跨域来源，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
LOG_FILE=data/arche.log

# === MinIO 对象存储 ===

MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=archeadmin
MINIO_ROOT_PASSWORD=archeadmin123
MINIO_SECURE=false

# === 阿里云 OSS（冷存储，可选）===

OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=

# === 云训练 Provider ===

# 可选: mock | zhixingyun | aliyun
CLOUD_PROVIDER=mock

# 智星云
ZHIXINGYUN_API_KEY=
ZHIXINGYUN_API_SECRET=

# 阿里云 ECS
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_REGION=cn-shanghai
ALIYUN_SECURITY_GROUP_ID=
ALIYUN_VSWITCH_ID=
ALIYUN_IMAGE_ID=

# 通用（mock 等）
CLOUD_API_KEY=
CLOUD_API_SECRET=

# 自动化部署密钥
DEPLOY_TOKEN=0-d-ad-sa23-213rfscd-d23e

# === GitHub（可选）===

GITHUB_TOKEN=
GITHUB_API_BASE=https://api.github.com
GITHUB_RAW_BASE=https://raw.githubusercontent.com
GITHUB_CACHE_TTL=300
GITHUB_TIMEOUT=30

# === 爬虫（可选）===

CRAWLER_SEEDS=https://www.zhihu.com
CRAWLER_STORAGE_ROOT=data/crawler

# === 系统监控（可选）===

MONITOR_COLLECT_INTERVAL=10

# === 敏感词过滤（可选）===

SENSITIVE_WORDS=
